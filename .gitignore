__pycache__/
*.py[cod]
*$py.class
*.pyo
.pytest_cache/

# ── Jupyter Notebook checkpoints ─────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Môi trường ảo Python ─────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ── Hệ điều hành ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Log & temp files ─────────────────────────────────────────────────────────
*.log
*.tmp
_tmp_*.jpg

# ── Chromium / undetected_chromedriver cache ──────────────────────────────────
undetected_chromedriver/

# ── Biến môi trường & secrets ────────────────────────────────────────────────
.env
.env.*
secrets.json
